ENVIRONMENT=staging
SUPABASE_STAGING_PROJECT_REF=wzwjjjajmyfwvspxysjb
SUPABASE_URL=https://wzwjjjajmyfwvspxysjb.supabase.co
SUPABASE_ANON_KEY=PASTE_STAGING_ANON_KEY_HERE

# Prefer Supabase Session Pooler for local RLS SQL tests on networks without IPv6.
# Copy it from Supabase Dashboard > Connect > Session pooler.
# Format:
# postgresql://postgres.<PROJECT_REF>:<URL_ENCODED_PASSWORD>@<POOLER_HOST>:5432/postgres?sslmode=require
#
# Do not use the direct host db.<PROJECT_REF>.supabase.co:5432 if your network/ISP/firewall
# cannot connect to Supabase over IPv6. Always keep sslmode=require.
# URL-encode special password characters before placing them in this URL.
# Never commit .env.rls.
SUPABASE_DB_URL=postgresql://postgres.wzwjjjajmyfwvspxysjb:PASTE_URL_ENCODED_DB_PASSWORD_HERE@PASTE_POOLER_HOST_HERE:5432/postgres?sslmode=require

RLS_NORMAL_EMAIL=normal@staging.ahorroya.test
RLS_NORMAL_PASSWORD=PASTE_TEMP_PASSWORD_HERE

RLS_ADMIN_EMAIL=admin@staging.ahorroya.test
RLS_ADMIN_PASSWORD=PASTE_TEMP_PASSWORD_HERE

RLS_INTERNAL_EMAIL=internal@staging.ahorroya.test
RLS_INTERNAL_PASSWORD=PASTE_TEMP_PASSWORD_HERE
