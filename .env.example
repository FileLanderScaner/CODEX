EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_APP_URL=https://project-6vgnm.vercel.app
EXPO_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
EXPO_PUBLIC_PREMIUM_PRICE=4.99
EXPO_PUBLIC_PREMIUM_CURRENCY=USD

# Accepted aliases when credentials come from Vercel/Next-style integrations
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_API_BASE_URL=https://project-6vgnm.vercel.app
NEXT_PUBLIC_APP_URL=https://project-6vgnm.vercel.app
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id

# Google OAuth - client ID used in web/mobile (public)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Server-side Google OAuth credentials (keep secret)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Optional: path to downloaded Google client_secret JSON (keep out of repo)
GOOGLE_OAUTH_JSON_PATH=./secrets/client_secret_yourapp.json

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your-paypal-server-client-id
PAYPAL_CLIENT_SECRET=your-paypal-server-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
PAYPAL_MONTHLY_PLAN_ID=P-xxxxxxxxxxxxxxxx
PAYPAL_YEARLY_PLAN_ID=P-yyyyyyyyyyyyyyyy
APP_URL=https://project-6vgnm.vercel.app
ALLOWED_ORIGINS=https://project-6vgnm.vercel.app,http://localhost:8081
CRON_SHARED_SECRET=your-cron-shared-secret
AFFILIATE_SIGNING_SECRET=your-affiliate-signing-secret
FEATURE_FLAGS={}
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
