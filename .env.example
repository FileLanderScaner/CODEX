EXPO_PUBLIC_API_BASE_URL=https://staging-preview.example.com
EXPO_PUBLIC_APP_URL=https://staging-preview.example.com
EXPO_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id
EXPO_PUBLIC_PREMIUM_PRICE=4.99
EXPO_PUBLIC_PREMIUM_CURRENCY=USD

# Accepted aliases when credentials come from Vercel/Next-style integrations
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_API_BASE_URL=https://staging-preview.example.com
NEXT_PUBLIC_APP_URL=https://staging-preview.example.com
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id

# Google OAuth - client ID used in web/mobile (public)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Server-side Google OAuth credentials (keep secret)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Optional: path to downloaded Google client_secret JSON (keep out of repo)
GOOGLE_OAUTH_JSON_PATH=./secrets/client_secret_yourapp.json

ENVIRONMENT=staging
SUPABASE_STAGING_PROJECT_REF=your-staging-project-ref
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres.your-staging-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your-paypal-server-client-id
PAYPAL_CLIENT_SECRET=your-paypal-server-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
PAYPAL_MONTHLY_PLAN_ID=P-xxxxxxxxxxxxxxxx
PAYPAL_YEARLY_PLAN_ID=P-yyyyyyyyyyyyyyyy
APP_URL=https://staging-preview.example.com
ALLOWED_ORIGINS=https://staging-preview.example.com
CRON_SHARED_SECRET=your-cron-shared-secret
AFFILIATE_SIGNING_SECRET=your-affiliate-signing-secret
FEATURE_FLAGS={}
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER=mock
AI_GATEWAY_ENABLED=false
AI_GATEWAY_MODEL=openai/gpt-5.5
AI_GATEWAY_MAX_OUTPUT_TOKENS=600
AI_GATEWAY_SMOKE_PROMPT_ENABLED=false
AI_KILL_SWITCH=false
# pulled by Vercel env pull, do not commit real value
VERCEL_OIDC_TOKEN=
AI_AUTONOMY_LEVEL=LEVEL_0_READ_ONLY
ENABLE_AI_AGENTS=false
ENABLE_AGENT_SCHEDULER=false
ENABLE_ADMIN_AI_PANEL=false
ENABLE_AI_LEVEL4_OVERRIDE=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
