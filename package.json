{
  "name": "ahorroya",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "build": "npx expo export --platform web",
    "lint": "node scripts/lint-basic.mjs",
    "typecheck": "node scripts/typecheck-js.mjs",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:contract": "vitest run tests/contract",
    "test:security": "vitest run tests/security",
    "test:e2e": "playwright test",
    "ci": "npm run lint && npm run typecheck && npm test && npm run build",
    "db:push": "npx supabase db push",
    "vercel:preview": "npx vercel deploy",
    "vercel:prod": "npx vercel deploy --prod"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@playwright/test": "^1.59.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.105.0",
    "csv-parse": "^5.6.0",
    "date-fns": "^4.1.0",
    "expo": "~53.0.10",
    "expo-status-bar": "~2.2.3",
    "fast-xml-parser": "^5.7.2",
    "msw": "^2.13.6",
    "pdf-parse": "^1.1.4",
    "pino": "^9.14.0",
    "playwright": "^1.59.1",
    "qrcode": "^1.5.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.20.0",
    "soap": "^1.9.1",
    "supertest": "^7.2.2",
    "vitest": "^3.2.4",
    "zod": "^3.25.76"
  }
}
