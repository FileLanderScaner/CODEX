{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "crons": [
    {
      "path": "/api/v1/internal/import/uy_uam_mgap",
      "schedule": "0 14 * * 1,4"
    },
    {
      "path": "/api/v1/internal/import/cl_odepa",
      "schedule": "0 12 * * 1-5"
    },
    {
      "path": "/api/v1/internal/import/co_sipsa",
      "schedule": "30 19 * * 1-5"
    },
    {
      "path": "/api/v1/internal/import/mx_profeco_qqp",
      "schedule": "0 10 2 * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/v1/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/_expo/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self)"
        }
      ]
    }
  ]
}
